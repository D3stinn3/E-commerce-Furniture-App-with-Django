# Copy this file to ".env" and fill in real values. The .env file is gitignored.

# --- Django core ---
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# --- Email (Gmail SMTP) ---
# EMAIL_HOST_USER is the sending Gmail account.
# EMAIL_HOST_PASSWORD is a Google App Password (NOT your normal password).
# EMAIL_RECEIVING_USER is where contact-form messages are delivered.
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_RECEIVING_USER=

# --- Paystack ---
# Get these from https://dashboard.paystack.com/#/settings/developers
# Use test keys (sk_test_... / pk_test_...) for development.
PAYSTACK_SECRET_KEY=sk_test_xxx
PAYSTACK_PUBLIC_KEY=pk_test_xxx
PAYSTACK_CURRENCY=KES

# Base URL of this site (used to build the Paystack payment callback URL).
BASE_URL=http://localhost:8000
